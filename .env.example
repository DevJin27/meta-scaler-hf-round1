PORT=10000
HOST=0.0.0.0
REDIS_URL=redis://your-render-keyvalue-host:6379
ADMIN_SECRET=replace-me
CLIENT_ORIGINS=https://your-frontend.example.com
LOG_LEVEL=info
ROUND_DURATION_MS=10000
INTER_ROUND_DELAY_MS=3000
AUTO_ADVANCE_ROUNDS=true
SOCKET_PATH=/socket.io
REDIS_KEY_PREFIX=signal-game
PING_INTERVAL_MS=25000
PING_TIMEOUT_MS=20000
LIFECYCLE_TICK_MS=500
LOCK_TTL_MS=4000
MAX_TEAMS=10
